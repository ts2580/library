{
  "name": "bookshelf",
  "version": "1.0.0",
  "description": "Spring Boot 프로젝트 초기 템플릿 (Java 21)",
  "main": "index.js",
  "scripts": {
    "test": "./gradlew test",
    "db:verify:sqlite": "bash scripts/verify_sqlite_storage.sh",
    "db:verify:migrated": "bash scripts/verify_migrated_sqlite.sh",
    "screen:smoke": "bash scripts/verify_screen_smoke.sh",
    "verify:local": "bash -n run.sh && bash -n scripts/verify_sqlite_storage.sh && bash -n scripts/verify_java_repositories.sh && bash -n scripts/verify_java_compile.sh && bash -n scripts/verify_migrated_sqlite.sh && bash -n scripts/verify_screen_smoke.sh && npm run db:verify:sqlite && bash scripts/verify_java_repositories.sh && bash scripts/verify_java_compile.sh && npm run css:build",
    "css:build": "tailwindcss -i src/main/resources/static/css/blinko-tailwind-input.css -o src/main/resources/static/css/blinko-tailwind.css --content \"./src/main/resources/templates/**/*.html\" \"./src/main/resources/static/js/**/*.js\"",
    "css:watch": "tailwindcss -i src/main/resources/static/css/blinko-tailwind-input.css -o src/main/resources/static/css/blinko-tailwind.css --content \"./src/main/resources/templates/**/*.html\" \"./src/main/resources/static/js/**/*.js\" --watch"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "tailwindcss": "^3.4.17"
  }
}
